<section class="section">
  <h2 class="section-title">アイテム作成</h2>
  <%= form_with model: @item, html: { class: "input-form" } do |f| %>
    <div><%= f.label :name, "アイテム名" %></div>
    <div><%= f.text_field :name %></div>
    <div class="field item-category-wrap">
      <%= f.label :category_id, "カテゴリー", class: "item-category-label" %>
      <%= f.collection_select :category_id, @categories, :id, :name, { prompt: "選択してください。" }, { class: "item-category-select" } %>
    </div>

    <div><%= f.submit "作成する", class: "submit-btn" %></div>
  <% end %>
  <p><%= link_to "戻る", items_path %></p>
</section>
