<h2>カテゴリー一覧</h2>
<p><%= link_to "カテゴリーを作成", new_category_path %></p>
<% if @categories.empty? %>
  <p>カテゴリーがありません。</p>
<% else %>
  <ul>
    <% @categories.each do |category| %>
      <li>
        <%= category.name %>
        <%= link_to "詳細", category_path(category) %>
        <%= link_to "編集", edit_category_path(category) %>
        <%= link_to "削除", category_path(category), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" } %>
      </li>
    <% end %>
  </ul>
<% end %>
