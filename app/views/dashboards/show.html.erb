<% content_for :title, "ダッシュボード" %>

<section class="section">
  <h2 class="section-title">ダッシュボード</h2>
  <p class="greeting">こんにちは、<%= current_user.name %>さん</p>

  <div class="dashboard-content">
    <% if current_user.group.present? %>
      <div class="group-name">
        <p>所属グループ名: <%= current_user.group.name %></p>
        <%= link_to edit_group_path, class: "edit-btn" do %>
          <%= image_tag "edit-icon.svg", alt: "編集アイコン" %>
        <% end %>
      </div>
      <p class="invite-token">招待トークン: <%= current_user.group.invite_token %></p>
      <div class="group-user-card">
        <h3 class="group-user-headline">所属ユーザー</h3>
        <ul class="group-user-list">
          <% @group_users.each do |user| %>
            <li class="group-user-item">
              <%= user.name %>
            </li>
          <% end %>
        </ul>
      </div>
    <% else %>
      <p class="no-group-message">グループの作成か参加をしてください。</p>
      <div class="dashboard-btns">
        <%= link_to "グループを作成", new_group_path, class: "link-btn" %>
        <%= link_to "グループに参加", join_group_path, class: "link-btn" %>
      </div>
    <% end %>
  </div>
</section>
